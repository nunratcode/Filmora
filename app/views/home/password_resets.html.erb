<%= stylesheet_link_tag "fonts", media: "all" %>
<%= stylesheet_link_tag "colors", media: "all" %>
<%= stylesheet_link_tag "signin", media: "all" %>
<%= javascript_include_tag "email_password_input", defer: true %>

<body>
    
    <!-- ХЕДЕР -->
    <header class="header">
        <div class="header_logo">FILMORA</div>

        <nav class="nav">
            <a href="/about">О нас</a>
            <a href="/feed">Лента</a>
            <a href="/subscription">Подписка</a>
        </nav>

        <div class="icons">
            <% if user_signed_in? %>
            <a href="/letterbox">
                <%= image_tag "letterbox.svg", class: "icon" %>
            </a>
            <% end %>
            <a href="/favorites">
            <%= image_tag "favorites.svg", class: "icon" %>
            </a>
            <a href="/signin">
            <%= image_tag "user.svg", class: "icon" %>
            </a>
        </div> 
    </header>

    <!-- ОСНОВНОЕ -->
    <main class="login_page">
        <div class="big">СБРОС ПАРОЛЯ</div>

        <div class="card-wrapper">
            <%= form_with url: password_resets_path, method: :post, html: { class: "card", id: "password-reset-form" }, local: false do %>
                <label>E-mail</label>
                <%= email_field_tag :email, nil, placeholder: "Введите ваш e-mail", class: "email_box" %>
                <%= submit_tag "Сбросить пароль", class: "button", id: "reset-button" %>
            <% end %>

            <div class="links">
                <a href="/signin">Уже есть аккаунт?</a>
            </div>
        </div>
    </main>

    <script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("password-reset-form");
        const button = document.getElementById("reset-button");

        if(form && button) {
            form.addEventListener("ajax:success", (event) => {
                const [data, status, xhr] = event.detail;
                button.value = data.message;
                button.disabled = true; // блокируем кнопку после успеха
            });

            form.addEventListener("ajax:error", (event) => {
            const [data, status, xhr] = event.detail;
            button.value = data.message;
            });
        }
    });
    </script>

    <!-- ФУТЕР -->
    <footer class="footer">
        
        <div class="footer_info">
        <div>
            <span class="label">
            <span class="grey_text">создательницы:</span><br>
            <span class="black_text">Александра Арефьева</span><br>
            <span class="black_text">Старовойтова Евгения</span>
        </div>

        <div>
            <span class="label">
            <span class="grey_text">кураторы:</span><br>
            <span class="black_text">Федор Ноздрин</span><br>
            <span class="black_text">Захар День</span>
        </div>
        </div>
    </footer>

</body>
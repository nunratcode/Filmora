<%= stylesheet_link_tag "fonts", media: "all" %>
<%= stylesheet_link_tag "colors", media: "all" %>
<%= stylesheet_link_tag "signin", media: "all" %>
<%= javascript_include_tag "email_password_input", defer: true %>

<body>
    <!-- ХЕДЕР -->
    <header class="header">
        <div class="header_logo">FILMORA</div>

        <nav class="nav">
            <a href="/about">О нас</a>
            <a href="/feed">Лента</a>
            <a href="/subscription">Подписка</a>
        </nav>

        <div class="icons">
            <% if user_signed_in? %>
                <%= button_to signout_path, method: :delete, class: "icon_button" do %>
                    <%= image_tag "exit.svg", class: "icon" %>
                <% end %>
            <% end %>

            <a href="/favorites">
            <%= image_tag "favorites.svg", class: "icon" %>
            </a>

            <% if user_signed_in? %>
                <a href="/user">
                    <%= image_tag "user.svg", class: "icon" %>
                </a>
            <% else %>
                <a href="/signin">
                    <%= image_tag "user.svg", class: "icon" %>
                </a>
            <% end %>
        </div> 
    </header>

    <!-- ОСНОВНОЕ -->
    <main class="login_page">
        <div class="big">РЕГИСТРАЦИЯ</div>

        <div class="card-wrapper">
            <%= form_with model: @user, url: registration_path, method: :post, html: { class: "card" } do |f| %>

                <label>E-mail</label>
                <%= f.email_field :email, placeholder: "Введите ваш e-mail", class: "email_box" %>

                <label>Никнейм</label>
                <%= f.text_field :username, placeholder: "Придумайте никнейм", class: "username_box" %>

                <label>Пароль</label>
                <%= f.password_field :password, placeholder: "Придумайте пароль", class: "password_box" %>

                <%= f.submit "Зарегистрироваться", class: "button" %>

            <% end %>

            <div class="links">
                <a href="/signin">Уже есть аккаунт?</a>
            </div>
        </div>
    </main>

    <!-- ФУТЕР -->
    <footer class="footer">
        
        <div class="footer_info">
        <div>
            <span class="label">
            <span class="grey_text">создательницы:</span><br>
            <span class="black_text">Александра Арефьева</span><br>
            <span class="black_text">Старовойтова Евгения</span>
        </div>

        <div>
            <span class="label">
            <span class="grey_text">кураторы:</span><br>
            <span class="black_text">Федор Ноздрин</span><br>
            <span class="black_text">Захар День</span>
        </div>
        </div>
    </footer>

</body>